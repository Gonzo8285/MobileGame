# --- Secrets (NEVER commit) ---
secrets/
*.pat
*.token
*.pem
*.key
.env
.env.*

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Godot 4 engine artefacts ---
# Generated import metadata and engine cache
.godot/
.import/
*.import
