.mono/
mono_crash.*.json

# --- Build outputs ---
build/
builds/
dist/
out/
exports/
*.apk
*.aab
*.ipa
*.app
*.exe
*.pck

# --- Logs, temp ---
*.log
logs/
tmp/
temp/

# --- Node / web (Phaser fallback or tooling) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# --- Python (any tooling scripts) ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- Coverage / test reports ---
coverage/
*.coverage
htmlcov/
