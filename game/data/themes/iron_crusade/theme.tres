[resource]
script = ExtResource("1_theme")
id = &"iron_crusade"
display_name = "The Iron Crusade"
category = 1
era = "crusader_heraldic"
status = 1
palette = Array[Color]([Color("#A82A2A"), Color("#E8E8E8"), Color("#C9A35A"), Color("#1A2A4A"), Color("#7A7A7A")])
fonts = {}
frame_default_variant = &"cross_fleur"
preview_art_path = ""
price_tier_gbp = 5.99
bundle_includes_board = true
bundle_includes_back = true
bundle_includes_avatar_frame = true
pass_plus_free_in_season = &""
subscription_quarterly_free = false
always_owned = false
owned_at_account_create = false
card_theme_treatments = Array[ExtResource("2_ctt")]([SubResource("ctt_0"), SubResource("ctt_1"), SubResource("ctt_2"), SubResource("ctt_3"), SubResource("ctt_4")])
pitch = "Crusader / holy-knight theme. Parallel to Iron Penitents but cleaner heraldry, less folk-horror, more honour-and-banners epic-fantasy. Iron Penitents = Templar order; Ash Mourners = monks of the sealed scripture; Coven = heretic mystics; Last Legion = banneret companies; Skinward Pact = wild-knights of the unconquered marches."
ip_notes = "Internal inspiration only: LOTR-adjacent territory Paul wants. Middle-earth is Tolkien Estate — NEVER named in customer copy. All names here are generic medieval-religious-knight-original. Audit 2026-05-25."
