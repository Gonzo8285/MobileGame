[resource]
script = ExtResource("1_theme")
id = &"hollowing_hall"
display_name = "The Hollowing Hall"
category = 1
era = "magical_school"
status = 1
palette = Array[Color]([Color("#1A2540"), Color("#1A1A1A"), Color("#E8DEB6"), Color("#A82A2A"), Color("#3A5A7A"), Color("#C9A35A")])
fonts = {}
frame_default_variant = &"doodle_margin"
preview_art_path = ""
price_tier_gbp = 3.99
bundle_includes_board = true
bundle_includes_back = true
bundle_includes_avatar_frame = true
pass_plus_free_in_season = &""
subscription_quarterly_free = false
always_owned = false
owned_at_account_create = false
card_theme_treatments = Array[ExtResource("2_ctt")]([SubResource("ctt_0"), SubResource("ctt_1"), SubResource("ctt_2"), SubResource("ctt_3"), SubResource("ctt_4")])
pitch = "A bright, doodly, kid-friendly magical school where the lessons go wrong in fun-spooky ways. Reads as bright sketchy ink art, jolly stained-glass palette, doodled monsters in textbook margins. Iron Penitents = stern caretakers; Ash Mourners = ghosts of past students; Coven = potion-club; Last Legion = chess-club tournament knights; Skinward Pact = wild-magic kids who keep turning into things. The only theme that softens the grimdark."
ip_notes = "Internal inspiration only: Wizarding World tonal slot Paul wants. Wizarding World / Harry Potter is Warner / Rowling — NEVER named in customer copy. Custom school name 'The Hollowing Hall' is Gallowfell-original. Audit 2026-05-25."
