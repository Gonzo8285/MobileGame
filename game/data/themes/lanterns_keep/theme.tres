[resource]
script = ExtResource("1_theme")
id = &"lanterns_keep"
display_name = "The Lantern's Keep"
category = 1
era = "cozy_cottagecore"
status = 1
palette = Array[Color]([Color("#E8B26C"), Color("#3A5A3A"), Color("#E8DEB6"), Color("#5C3A6A"), Color("#A06A3A")])
fonts = {}
frame_default_variant = &"knotted_wood_ivy"
preview_art_path = ""
price_tier_gbp = 3.99
bundle_includes_board = true
bundle_includes_back = true
bundle_includes_avatar_frame = true
pass_plus_free_in_season = &""
subscription_quarterly_free = false
always_owned = false
owned_at_account_create = false
card_theme_treatments = Array[ExtResource("2_ctt")]([SubResource("ctt_0"), SubResource("ctt_1"), SubResource("ctt_2"), SubResource("ctt_3"), SubResource("ctt_4")])
pitch = "Cozy-fantasy theme. Warm lantern light, soft palette, mushroom forests, knitted-hat hedgehog warriors, lantern-keeper grandmothers. Iron Penitents = forest-keeper rangers; Ash Mourners = mushroom-druid herbalists; Coven = tea-witches; Last Legion = badger-knight order; Skinward Pact = friendly were-creatures. Tonal counterpoint to canonical Gallowfell."
ip_notes = "Internal inspiration only: Wildfrost's tone (Chucklefish, do NOT name in customer copy). All names here are Gallowfell-original. Audit 2026-05-25."
