[resource]
script = ExtResource("1_theme")
id = &"cosmic_drowning"
display_name = "The Cosmic Drowning"
category = 0
era = "lovecraftian"
status = 1
palette = Array[Color]([Color("#0A1A1A"), Color("#2A6A6A"), Color("#7AE0A8"), Color("#E8E0C0"), Color("#000A14")])
fonts = {}
frame_default_variant = &"tentacle_glyph"
preview_art_path = ""
price_tier_gbp = 5.99
bundle_includes_board = true
bundle_includes_back = true
bundle_includes_avatar_frame = true
pass_plus_free_in_season = &"season_3"
subscription_quarterly_free = false
always_owned = false
owned_at_account_create = false
card_theme_treatments = Array[ExtResource("2_ctt")]([SubResource("ctt_0"), SubResource("ctt_1"), SubResource("ctt_2"), SubResource("ctt_3"), SubResource("ctt_4")])
pitch = "Lovecraftian cosmic horror. The curse of Gallowfell reinterpreted as a sleeper-god awakening beneath the seabed. Iron Penitents = cultists of the deep church; Ash Mourners = those who saw too much; Coven = star-witches reading non-Euclidean geometry; Last Legion = drowned navy regiment; Skinward Pact = those bargained with the deep ones, slowly turning fish-eyed."
ip_notes = "Lovecraft mythos pre-1929 (Cthulhu / Dagon / Hastur / Nyarlathotep / Innsmouth all PD; Lovecraft died 1937, US works pre-1929 PD). AVOID post-1929 elements like Mountains of Madness. Audit 2026-05-25."
