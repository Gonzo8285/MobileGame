[resource]
script = ExtResource("1_theme")
id = &"underworlds_maw"
display_name = "The Underworld's Maw"
category = 0
era = "greek_underworld"
status = 1
palette = Array[Color]([Color("#1A0A0A"), Color("#A82A2A"), Color("#C9A35A"), Color("#0A0A0A"), Color("#5C2A2A")])
fonts = {}
frame_default_variant = &"meander_key"
preview_art_path = ""
price_tier_gbp = 5.99
bundle_includes_board = true
bundle_includes_back = true
bundle_includes_avatar_frame = true
pass_plus_free_in_season = &""
subscription_quarterly_free = false
always_owned = false
owned_at_account_create = false
card_theme_treatments = Array[ExtResource("2_ctt")]([SubResource("ctt_0"), SubResource("ctt_1"), SubResource("ctt_2"), SubResource("ctt_3"), SubResource("ctt_4")])
pitch = "Greek underworld. Hades / Cerberus / Sisyphus / Charon / the Furies. Iron Penitents = Spartan hoplite phalanx of the dead; Ash Mourners = Furies and shade-priests; Coven = oracles at the bone-altar; Last Legion = Charon's ferrymen-army; Skinward Pact = satyr/centaur shape-bound. Palette: Attic-vase black-and-red, ochre gold. Frame: meander key-border and laurel-wreath corners."
ip_notes = "Greek mythology — all Olympian + chthonic + monster — fully PD. Audit 2026-05-25."
